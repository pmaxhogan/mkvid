PORT=8080
DATA_DIR=./data
# Cloudflare Access (leave DEV_BYPASS on for local)
DEV_BYPASS_CF_ACCESS=1
CF_ACCESS_TEAM_DOMAIN=pmaxhogan.cloudflareaccess.com
CF_ACCESS_AUD=
CF_ACCESS_ALLOWED_EMAILS=pmaxhogan@gmail.com
# Google OAuth (YouTube upload)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:8080
DEFAULT_PRIVACY=private
YOUTUBE_CATEGORY_ID=10
YOUTUBE_PLAYLIST_ID=
# Web Push (generate with: npm run vapid)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:pmaxhogan@gmail.com
# Binaries (entrypoint overrides these to $DATA_DIR/bin when auto-updated)
FFMPEG_PATH=ffmpeg
FFPROBE_PATH=ffprobe
YTDLP_PATH=yt-dlp
# Leave at 0: uses bundled jellyfin-ffmpeg (WORKING NVENC). 1 = fetch the latest
# static ffmpeg build, but that build's h264_nvenc rejects -cq and forces CPU.
FFMPEG_AUTOUPDATE=0
